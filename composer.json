{
    "name": "karelwintersky/grasp",
    "description": "GRASP - Git Repository Aggregation & Storage Platform",
    "type": "project",
    "authors": [
        {
            "name": "Karel Wintersky",
            "email": "karel@wintersky.ru"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-redis": "*",
        "karelwintersky/arris": "^2.99",
        "karelwintersky/arris.router": "^2.3",
        "karelwintersky/arris.logger": "^2.1",
        "karelwintersky/arris.toolkit.cli-console": "^1.4"
    },
    "config": {
        "optimize-autoloader": true,
        "vendor-dir": "vendor",
        "platform-check": false
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"if(!is_dir('storage')) mkdir('storage', 0755, true);\"",
            "php -r \"if(!is_dir('logs')) mkdir('logs', 0755, true);\""
        ]
    }
}
